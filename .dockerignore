# ============================================
# Docker 构建忽略文件
# ============================================
# 这些文件不会被发送到 Docker build context

# Git
.git/
.gitignore
.gitattributes

# 文档
*.md
README*
docs/

# 环境变量（使用 --env-file 传递）
.env
.env.local

# IDE
.vscode/
.idea/
*.swp
*.swo

# 日志
*.log
logs/

# 临时文件
tmp/
temp/
*.tmp

# OS 文件
.DS_Store
Thumbs.db

# 测试文件
tests/
test/
*.test.*
__tests__/

# CI/CD
.github/
.gitlab-ci.yml
.travis.yml

# Docker
docker-compose*.yml
.docker/

# 依赖（会在镜像构建时安装）
node_modules/
venv/
__pycache__/

# 备份
*.bak
*.backup
*.old
