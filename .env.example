# ============================================
# AI Dev Environment Configuration
# ============================================
# 复制此文件为 .env 并修改相应的值
# cp .env.example .env

# ---- SSH 配置 ----
# SSH 服务端口（宿主机映射端口）
DEVPOD_SSH_PORT=1122
SSH_KEY_PATH=~/.ssh/id_rsa
# Root 用户密码（建议使用强密码）
DEVPOD_ROOT_PASSWORD=changeme321

# ---- 容器配置 ----
# 容器名称
DEVPOD_CONTAINER_NAME=dev-pod

# 工作目录挂载路径（宿主机路径）
DEVPOD_WORKSPACE=/Users/zou/workspace

# ---- Node.js 配置 ----
# Node.js 版本
NODE_VERSION=24.1.0

# ---- 时区配置 ----
TZ=Asia/Shanghai

# ---- AI 工具配置 ----
# Claude API Key (如需要)
# ANTHROPIC_API_KEY=your_api_key_here

# OpenAI API Key (如需要)
# OPENAI_API_KEY=your_api_key_here

# ---- GitHub 配置 ----
# GitHub Token (用于 gh CLI，可选)
# GITHUB_TOKEN=your_github_token_here

# ---- Docker 配置 ----
# 是否挂载宿主机 Docker socket (允许容器内操作宿主机 Docker)
# MOUNT_DOCKER_SOCKET=true

# ---- 资源限制 ----
# CPU 限制（核心数）
# DEVPOD_CPU_LIMIT=2

# 内存限制
# DEVPOD_MEMORY_LIMIT=4g

# ---- 代理配置（如需要）----
# HTTP_PROXY=http://proxy.example.com:8080
# HTTPS_PROXY=http://proxy.example.com:8080
# NO_PROXY=localhost,127.0.0.1
SHENGSUANYUN_API_KEY= your_api_key_here
SHENGSUANYUN_CP_API_KEY= your_ssy_cp_api_key_here